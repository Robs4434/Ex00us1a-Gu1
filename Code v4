local themeElements = {}
local function RegisterAccent(object, property)
    table.insert(themeElements, {Object = object, Property = property})
end

local function UpdateThemeColor(color)
    for _, item in ipairs(themeElements) do
        pcall(function()
            if item.Object and item.Object.Parent then
                item.Object[item.Property] = color
            end
        end)
    end
end

local rainbowActive = false
local rainbowConnection = nil

local function SetRainbow(state)
    rainbowActive = state
    if rainbowActive then
        if rainbowConnection then rainbowConnection:Disconnect() end
        rainbowConnection = RunService.RenderStepped:Connect(function()
            local hue = (tick() % 5) / 5 
            local color = Color3.fromHSV(hue, 1, 1)
            UpdateThemeColor(color)
        end)
    else
        if rainbowConnection then
            rainbowConnection:Disconnect()
            rainbowConnection = nil
        end
        UpdateThemeColor(COLORS.Accent)
    end
end


