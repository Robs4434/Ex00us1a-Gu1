local resizeToggle = false
local resizeType = ""
local resizeStartSize = Vector2.new(0, 0)
local resizeDragStart = Vector2.new(0, 0)

local function startResize(input, rType)
    resizeToggle = true
    resizeType = rType
    resizeDragStart = input.Position
    resizeStartSize = Vector2.new(MainFrame.AbsoluteSize.X, MainFrame.AbsoluteSize.Y)
    
    input.Changed:Connect(function()
        if input.UserInputState == Enum.UserInputState.End then
            resizeToggle = false
        end
    end)
end

ResizeRight.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then startResize(input, "Right") end
end)
ResizeBottom.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then startResize(input, "Bottom") end
end)
ResizeCorner.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then startResize(input, "Corner") end
end)

UserInputService.InputChanged:Connect(function(input)
    if resizeToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - resizeDragStart
        local newWidth, newHeight = resizeStartSize.X, resizeStartSize.Y
        if resizeType == "Right" or resizeType == "Corner" then newWidth = math.clamp(resizeStartSize.X + delta.X, MIN_WIDTH, MAX_WIDTH) end
        if resizeType == "Bottom" or resizeType == "Corner" then newHeight = math.clamp(resizeStartSize.Y + delta.Y, MIN_HEIGHT, MAX_HEIGHT) end
        MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
    end
end)

