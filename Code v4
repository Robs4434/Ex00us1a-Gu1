local function CreateSlider(text, min, max, default, tabParent, callback)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, -5, 0, 50)
    container.BackgroundColor3 = COLORS.Panel
    container.BorderColor3 = COLORS.Accent
    RegisterAccent(container, "BorderColor3")
    container.Parent = tabParent

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -10, 0, 20)
    label.Position = UDim2.new(0, 5, 0, 2)
    label.BackgroundTransparency = 1
    label.Text = text .. ": " .. tostring(default)
    label.TextColor3 = COLORS.Text
    RegisterAccent(label, "TextColor3")
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Code
    label.TextSize = 12
    label.Parent = container

    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(1, -20, 0, 10)
    sliderBg.Position = UDim2.new(0, 10, 0, 30)
    sliderBg.BackgroundColor3 = COLORS.Background
    sliderBg.BorderColor3 = COLORS.Accent
    RegisterAccent(sliderBg, "BorderColor3")
    sliderBg.Parent = container

    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    sliderFill.BackgroundColor3 = COLORS.Accent
    RegisterAccent(sliderFill, "BackgroundColor3")
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderBg

    -- КНОПКА ПОЛЗУНКА
    local sliderBtn = Instance.new("TextButton")
    sliderBtn.Size = UDim2.new(0, 12, 0, 20)
    sliderBtn.Position = UDim2.new((default - min) / (max - min), -6, 0.5, -10)
    sliderBtn.BackgroundColor3 = COLORS.Accent
    RegisterAccent(sliderBtn, "BackgroundColor3")
    sliderBtn.BorderSizePixel = 1
    sliderBtn.BorderColor3 = Color3.fromRGB(255, 255, 255)
    sliderBtn.Text = ""
    sliderBtn.Parent = sliderBg

    local dragging = false
    local function updateSlider(input)
        local posX = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        TweenService:Create(sliderBtn, TweenInfo.new(0.05), {Position = UDim2.new(posX, -6, 0.5, -10)}):Play()
        TweenService:Create(sliderFill, TweenInfo.new(0.05), {Size = UDim2.new(posX, 0, 1, 0)}):Play()
        local val = math.floor(min + (max - min) * posX)
        label.Text = text .. ": " .. tostring(val)
        callback(val)
    end

    sliderBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then 
            PlayClick()
            dragging = true 
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then updateSlider(input) end
    end)
end


