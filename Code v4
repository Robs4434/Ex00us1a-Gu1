local function CreateTab(name, icon)
    local tabBtn = Instance.new("TextButton")
    tabBtn.Size = UDim2.new(0.9, 0, 0, 30)
    tabBtn.BackgroundColor3 = COLORS.Background
    tabBtn.BorderColor3 = COLORS.Accent
    RegisterAccent(tabBtn, "BorderColor3")
    tabBtn.Text = icon .. " " .. name
    tabBtn.TextColor3 = COLORS.Text
    RegisterAccent(tabBtn, "TextColor3")
    tabBtn.Font = Enum.Font.Code
    tabBtn.TextSize = 13
    tabBtn.Parent = Sidebar

    
    tabBtn.MouseEnter:Connect(function()
        TweenService:Create(tabBtn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = UDim2.new(0.95, 0, 0, 30)}):Play()
    end)
    tabBtn.MouseLeave:Connect(function()
        TweenService:Create(tabBtn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = UDim2.new(0.9, 0, 0, 30)}):Play()
    end)

    local scrollFrame = Instance.new("ScrollingFrame")
    scrollFrame.Size = UDim2.new(1, -10, 1, -10)
    scrollFrame.Position = UDim2.new(0, 5, 0, 5)
    scrollFrame.BackgroundTransparency = 1
    scrollFrame.ScrollBarThickness = 4
    scrollFrame.ScrollBarImageColor3 = COLORS.Accent
    RegisterAccent(scrollFrame, "ScrollBarImageColor3")
    scrollFrame.Visible = false
    scrollFrame.Parent = ContentArea
    
    local UIListLayout = Instance.new("UIListLayout")
    UIListLayout.Padding = UDim.new(0, 8)
    UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    UIListLayout.Parent = scrollFrame
    
    UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
    end)

    tabs[name] = {Button = tabBtn, Frame = scrollFrame}

    tabBtn.MouseButton1Click:Connect(function()
        if currentTab == name then return end
        PlayClick()
        if currentTab and tabs[currentTab] then
            TweenService:Create(tabs[currentTab].Button, TweenInfo.new(0.2), {BackgroundColor3 = COLORS.Background}):Play()
            tabs[currentTab].Frame.Visible = false
        end
        currentTab = name
        TweenService:Create(tabBtn, TweenInfo.new(0.2), {BackgroundColor3 = COLORS.Active}):Play()
        scrollFrame.Position = UDim2.new(0, -20, 0, 5)
        scrollFrame.Visible = true
        TweenService:Create(scrollFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0, 5, 0, 5)}):Play()
    end)

    return scrollFrame
end

