local function applyESP(player)
    if player == LocalPlayer then return end 
    
    local function setupHighlight(character)
        if not espActive then return end
        
        local oldHighlight = character:FindFirstChild("MyPlayerESP")
        if oldHighlight then oldHighlight:Destroy() end
        
        local highlight = Instance.new("Highlight")
        highlight.Name = "MyPlayerESP"
        
        highlight.FillColor = Color3.fromRGB(0, 255, 0)     
        highlight.FillTransparency = 0.5                     
        highlight.OutlineColor = Color3.fromRGB(0, 255, 0)   
        highlight.OutlineTransparency = 0                    
        
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = character
    end

    if player.Character then
        setupHighlight(player.Character)
    end

    local charAddedConn = player.CharacterAdded:Connect(setupHighlight)
    table.insert(espConnections, charAddedConn)
end

espButton = CreateHackButton("Player ESP 👥 ❌", 6.5, function()
    espActive = not espActive
    
    if espActive then
        espButton.Text = "  Player ESP 👥 ✅"
        espButton.BackgroundColor3 = Color3.fromRGB(0, 60, 10)
        
        for _, player in pairs(Players:GetPlayers()) do
            applyESP(player)
        end
        
        local playerAddedConn = Players.PlayerAdded:Connect(applyESP)
        table.insert(espConnections, playerAddedConn)
    else
        espButton.Text = "  Player ESP 👥 ❌"
        espButton.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        
        for _, connection in pairs(espConnections) do
            if connection then connection:Disconnect() end
        end
