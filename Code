local resizeConnection
resizeConnection = UserInputService.InputChanged:Connect(function(input)
    if resizeToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - resizeStartDrag
        local newWidth = resizeStartSize.X
        local newHeight = resizeStartSize.Y
        
        if resizeType == "X" or resizeType == "XY" then
            newWidth = math.max(MIN_SIZE.X, resizeStartSize.X + delta.X)
        end
        if resizeType == "Y" or resizeType == "XY" then
            newHeight = math.max(MIN_SIZE.Y, resizeStartSize.Y + delta.Y)
        end
        
        MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
    end
end)

