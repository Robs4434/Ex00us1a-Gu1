CreateHackButton("🚀 Server Hop", TabSettings, function()
    LogToConsole("Поиск нового сервера...", COLORS.Accent)
    task.spawn(function()
        local HttpService = game:GetService("HttpService")
        local TeleportService = game:GetService("TeleportService")
        local PlaceId = game.PlaceId
        local JobId = game.JobId

        local function fetchServers(cursor)
            local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
            if cursor then url = url .. "&cursor=" .. cursor end
            local success, result = pcall(function() return game:HttpGet(url) end)
            if success then return HttpService:JSONDecode(result) end
            return nil
        end

        local cursor = nil
        local attempts = 0
        while attempts < 10 do
            attempts = attempts + 1
            local data = fetchServers(cursor)
            if data and data.data then
                local possible = {}
                for _, server in ipairs(data.data) do
                    if type(server) == "table" and server.id ~= JobId and server.playing < server.maxPlayers then
                        table.insert(possible, server.id)
                    end
                end
                if #possible > 0 then
                    local chosen = possible[math.random(1, #possible)]
                    LogToConsole("Сервер найден! Телепортация...", COLORS.Accent)
                    local teleportSuccess, teleportError = pcall(function()
                        TeleportService:TeleportToPlaceInstance(PlaceId, chosen, LocalPlayer)
                    end)
                    if not teleportSuccess then
                        LogToConsole("Ошибка телепортации: " .. tostring(teleportError), Color3.fromRGB(255, 100, 100))
                    end
                    return
                end
                cursor = data.nextPageCursor
                if not cursor then break end
            else
                break
            end
        end
        LogToConsole("Не удалось найти подходящий server.", Color3.fromRGB(255, 100, 100))
    end)
end)

