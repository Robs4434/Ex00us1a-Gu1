local spiderActive, spiderConnection, spiderBtn = false, nil, nil
spiderBtn = CreateHackButton("Spider (Wall/Ceiling) [OFF]", TabMovement, function()
    spiderActive = not spiderActive
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    
    if spiderActive then
        spiderBtn.Text = "  > Spider (Wall/Ceiling) [ON]"
        LogToConsole("Spider (Wall & Ceiling): Активирован", COLORS.Accent)
        
        if hrp then
            local bv = Instance.new("BodyVelocity")
            bv.Name, bv.MaxForce, bv.Velocity, bv.Parent = "SpiderBV", Vector3.new(0, 0, 0), Vector3.new(0, 0, 0), hrp
        end
        
        spiderConnection = RunService.Heartbeat:Connect(function()
            local char = LocalPlayer.Character
            if not char then return end
            local root = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            local head = char:FindFirstChild("Head")
            if not root or not hum then return end
            
            local currentBV = root:FindFirstChild("SpiderBV") or Instance.new("BodyVelocity", root)
            currentBV.Name = "SpiderBV"
            
            local params = RaycastParams.new()
            params.FilterType, params.FilterDescendantsInstances = Enum.RaycastFilterType.Exclude, {char}
            
            local wallOrigin = root.Position
            local wallDirection = root.CFrame.LookVector * 4
            local wallResult = workspace:Raycast(wallOrigin, wallDirection, params)
            
            local ceilingOrigin = head and head.Position or root.Position
            local ceilingDirection = Vector3.new(0, 3.5, 0)
            local ceilingResult = workspace:Raycast(ceilingOrigin, ceilingDirection, params)
            
            local isWall = wallResult and math.abs(wallResult.Normal.Y) < 0.7
            local isCeiling = ceilingResult and ceilingResult.Normal.Y < -0.7
            
            if isWall then
                currentBV.MaxForce = Vector3.new(99999, 99999, 99999)
                local climbVelocity = Vector3.new(0, 0, 0)
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then climbVelocity = Vector3.new(0, currentSpeed or 16, 0)
                elseif UserInputService:IsKeyDown(Enum.KeyCode.S) then climbVelocity = Vector3.new(0, -(currentSpeed or 16), 0) end
                
                local horizontalVelocity = Vector3.new(0, 0, 0)
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then horizontalVelocity = -root.CFrame.RightVector * (currentSpeed or 16)
                elseif UserInputService:IsKeyDown(Enum.KeyCode.D) then horizontalVelocity = root.CFrame.RightVector * (currentSpeed or 16) end
                
                local stickForce = -wallResult.Normal * 12
                currentBV.Velocity = climbVelocity + horizontalVelocity + stickForce
            elseif isCeiling then
                currentBV.MaxForce = Vector3.new(99999, 99999, 99999)
                local look = root.CFrame.LookVector
                local flatLook = Vector3.new(look.X, 0, look.Z)
                flatLook = flatLook.Magnitude > 0 and flatLook.Unit or root.CFrame.LookVector
                
                local right = root.CFrame.RightVector
                local flatRight = Vector3.new(right.X, 0, right.Z)
                flatRight = flatRight.Magnitude > 0 and flatRight.Unit or root.CFrame.RightVector
                
                local forwardVelocity = Vector3.new(0, 0, 0)
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then forwardVelocity = flatLook * (currentSpeed or 16)
                elseif UserInputService:IsKeyDown(Enum.KeyCode.S) then forwardVelocity = -flatLook * (currentSpeed or 16) end
                
                local rightVelocity = Vector3.new(0, 0, 0)
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then rightVelocity = -flatRight * (currentSpeed or 16)
                elseif UserInputService:IsKeyDown(Enum.KeyCode.D) then rightVelocity = flatRight * (currentSpeed or 16) end
                
                local stickForce = -ceilingResult.Normal * 15
                currentBV.Velocity = forwardVelocity + rightVelocity + stickForce
            else
                currentBV.MaxForce = Vector3.new(0, 0, 0)
            end
        end)
    else
        spiderBtn.Text = "  > Spider (Wall/Ceiling) [OFF]"
        LogToConsole("Spider (Wall & Ceiling): Деактивирован", Color3.fromRGB(255, 100, 100))
        if spiderConnection then spiderConnection:Disconnect() spiderConnection = nil end
        if hrp and hrp:FindFirstChild("SpiderBV") then hrp.SpiderBV:Destroy() end
    end
end)

