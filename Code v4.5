        if humanoid then humanoid.PlatformStand = true end
        local bv = Instance.new("BodyVelocity")
        bv.Name, bv.MaxForce, bv.P, bv.Velocity, bv.Parent = "FlyBV", Vector3.new(math.huge, math.huge, math.huge), 100000, Vector3.new(0, 0, 0), hrp
        local bg = Instance.new("BodyGyro")
        bg.Name, bg.MaxTorque, bg.P, bg.CFrame, bg.Parent = "FlyBG", Vector3.new(math.huge, math.huge, math.huge), 100000, hrp.CFrame, hrp
        flyConnection = RunService.RenderStepped:Connect(function()
            local cam = workspace.CurrentCamera
            if not hrp or not hrp.Parent then return end
            local currentBV, currentBG = hrp:FindFirstChild("FlyBV"), hrp:FindFirstChild("FlyBG")
