    end

    createWheelAndSuspension(CFrame.new(-2.4, -1.2, -1.4), "Wheel_FL")
    createWheelAndSuspension(CFrame.new(5.4, -1.2, -1.4), "Wheel_FR") 
    createWheelAndSuspension(CFrame.new(-2.4, -1.2, 1.4), "Wheel_RL") 
    createWheelAndSuspension(CFrame.new(5.4, -1.2, 1.4), "Wheel_RR")  

    local function standUp()
        if activeSofaWeld then activeSofaWeld:Destroy() activeSofaWeld = nil end
        sofaCurrentSeat = nil
        local character = LocalPlayer.Character
        if character and character:FindFirstChildOfClass("Humanoid") then
            character:FindFirstChildOfClass("Humanoid").Sit = false
        end
    end

    sofaJumpConnection = UserInputService.JumpRequest:Connect(function()
        if activeSofaWeld then standUp() end
    end)

    local function setupSeatTouch(seat)
        seat.Touched:Connect(function(hit)
            if activeSofaWeld or sofaCurrentSeat then return end
            local character = LocalPlayer.Character
            if character and hit:IsDescendantOf(character) then
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                if humanoid and rootPart and humanoid.Health > 0 then
                    sofaCurrentSeat = seat
                    rootPart.CFrame = seat.CFrame * CFrame.new(0, 2.2, 0.8)
                    humanoid.Sit = true
                    
                    activeSofaWeld = Instance.new("WeldConstraint")
                    activeSofaWeld.Name = "LocalSeatWeld"
                    activeSofaWeld.Part0 = seat
                    activeSofaWeld.Part1 = rootPart
                    activeSofaWeld.Parent = rootPart
                end
            end
        end)
    end

    setupSeatTouch(driverSeat)
    setupSeatTouch(passengerSeat)

    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(0, 0, 0)
    bg.P = 5000
    bg.Parent = driverSeat

    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(0, 0, 0)
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.Parent = driverSeat

    local SPEED = 60       
    local TURN_SPEED = 4   
    local wheelRotation = 0

    sofaPhysicsConnection = RunService.RenderStepped:Connect(function(dt)
        if not driverSeat or not driverSeat.Parent then
            if sofaPhysicsConnection then sofaPhysicsConnection:Disconnect() sofaPhysicsConnection = nil end
            return
        end
        
        if sofaCurrentSeat == driverSeat then
            local throttle = 0
            local steer = 0
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) or UserInputService:IsKeyDown(Enum.KeyCode.Up) then throttle = 1
            elseif UserInputService:IsKeyDown(Enum.KeyCode.S) or UserInputService:IsKeyDown(Enum.KeyCode.Down) then throttle = -1 end
            
            if UserInputService:IsKeyDown(Enum.KeyCode.D) or UserInputService:IsKeyDown(Enum.KeyCode.Right) then steer = 1
            elseif UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.Left) then steer = -1 end
            
            bv.MaxForce = Vector3.new(30000, 0, 30000)
            bv.Velocity = driverSeat.CFrame.LookVector * (throttle * SPEED)
            
            driverSeat.AssemblyAngularVelocity = Vector3.new(0, -steer * TURN_SPEED, 0)
            
            bg.MaxTorque = Vector3.new(250000, 0, 250000)
            bg.CFrame = CFrame.new(driverSeat.Position, driverSeat.Position + driverSeat.CFrame.LookVector)
            
            local velocity = driverSeat.AssemblyLinearVelocity
            local forwardSpeed = velocity:Dot(driverSeat.CFrame.LookVector)
            if math.abs(forwardSpeed) > 0.5 then
                wheelRotation = wheelRotation + (forwardSpeed / 1.5) * dt
                for _, wheelData in ipairs(activeWheels) do
                    wheelData.weld.C0 = wheelData.initialOffset * CFrame.Angles(wheelRotation, 0, 0)
                end
            end
        else
            bv.MaxForce = Vector3.new(0, 0, 0)
            bg.MaxTorque = Vector3.new(0, 0, 0)
        end
    end)
end)

