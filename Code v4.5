local fnafEsp = false
local fnafFuse = false
local fnafClock = false
local fnafFarm = false
local fnafSaved = nil
local fuseCache = {}
local farmPart
local clockGui

if isFnafGame then
    task.spawn(function()
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart")

        LocalPlayer.CharacterAdded:Connect(function(c)
            char = c
            root = c:WaitForChild("HumanoidRootPart")
        end)

        local gameFolder = workspace:WaitForChild("Game", 10)
        if not gameFolder then return end

        local anims = gameFolder:WaitForChild("Animatronics", 5)
        local clockModel = gameFolder:WaitForChild("Clock", 5)
        if not anims or not clockModel then return end

        local surface = clockModel:WaitForChild("Part"):WaitForChild("SurfaceGui")
        local hours = surface:WaitForChild("Horas")
        local mins = surface:WaitForChild("Minutos")

        local function addESP(o)
            if not fnafEsp then return end
            if o:FindFirstChild("ESP") then return end
            if not (o:IsA("Model") or o:IsA("BasePart")) then return end

            local h = Instance.new("Highlight")
            h.Name = "ESP"
            h.FillColor = Color3.fromRGB(255,0,0)
            h.OutlineColor = Color3.fromRGB(255,255,255)
            h.Parent = o
        end

        local function espOn()
            fnafEsp = true
            for _,v in ipairs(anims:GetDescendants()) do
                addESP(v)
            end
        end

        local function espOff()
            fnafEsp = false
            for _,v in ipairs(workspace:GetDescendants()) do
                local h = v:FindFirstChild("ESP")
                if h then h:Destroy() end
            end
        end

        local function attachFuse(obj)
            if fuseCache[obj] then return end

            local h = Instance.new("Highlight")
            h.Name = "FUSE"
            h.FillColor = Color3.fromRGB(0,170,255)
            h.OutlineColor = Color3.fromRGB(255,255,255)
            h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            h.Parent = obj

            local part = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")) or obj
            if not part then return end

            local bb = Instance.new("BillboardGui")
            bb.Size = UDim2.new(0,120,0,40)
            bb.StudsOffset = Vector3.new(0,2.5,0)
            bb.AlwaysOnTop = true
            bb.Parent = part

            local txt = Instance.new("TextLabel")
            txt.Size = UDim2.new(1,0,1,0)
            txt.BackgroundTransparency = 1
            txt.Text = "FUSE"
            txt.Font = Enum.Font.GothamBlack
            txt.TextScaled = true
            txt.TextColor3 = Color3.fromRGB(0,170,255)
            txt.Parent = bb

            fuseCache[obj] = {h, bb}
        end

        local function fuseOn()
            fnafFuse = true
            task.spawn(function()
                while fnafFuse do
                    for _,v in ipairs(workspace:GetDescendants()) do
                        if v.Name == "Fuse" then
                            attachFuse(v)
                        end
                    end
                    task.wait(0.5)
                end
            end)

            task.spawn(function()
                while fnafFuse do
                    for obj,data in pairs(fuseCache) do
                        if not obj or not obj.Parent then
                            if data[1] then data[1]:Destroy() end
                            if data[2] then data[2]:Destroy() end
                            fuseCache[obj] = nil
                        end
                    end
                    task.wait(1)
                end
            end)
        end

        local function fuseOff()
            fnafFuse = false
            for _,v in pairs(fuseCache) do
                if v[1] then v[1]:Destroy() end
                if v[2] then v[2]:Destroy() end
            end
            table.clear(fuseCache)
        end

        local function clockOn()
            fnafClock = true
            clockGui = Instance.new("ScreenGui")
            clockGui.ResetOnSpawn = false
            clockGui.DisplayOrder = 2147483647
            local success, coreGui = pcall(game.GetService, game, "CoreGui")
            if success and coreGui then
                clockGui.Parent = coreGui
            else
                clockGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
            end

            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(0, 160, 0, 50)
            frame.Position = UDim2.new(0.5, -80, 0.05, 0)
            frame.BackgroundColor3 = COLORS.Background
            frame.BorderColor3 = COLORS.Accent
            frame.BorderSizePixel = 2
            frame.Parent = clockGui
            RegisterAccent(frame, "BorderColor3")

            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, 0, 1, 0)
            label.BackgroundTransparency = 1
            label.Font = Enum.Font.Code
            label.TextScaled = true 
            label.TextColor3 = COLORS.Text
            label.TextYAlignment = Enum.TextYAlignment.Center
            label.TextXAlignment = Enum.TextXAlignment.Center
            label.Parent = frame
            RegisterAccent(label, "TextColor3")

            task.spawn(function()
                while fnafClock do
                    pcall(function()
                        label.Text = hours.Text .. ":" .. mins.Text
                    end)
                    task.wait(0.1)
                end
            end)
        end

        local function clockOff()
            fnafClock = false
            if clockGui then clockGui:Destroy() end
        end

        local function farmToggle()
            if not root then return end
            if not fnafFarm then
                fnafSaved = root.CFrame
                root.CFrame += Vector3.new(0,300,0)

                farmPart = Instance.new("Part")
                farmPart.Size = Vector3.new(7,1,7)
                farmPart.Anchored = true
                farmPart.Position = root.Position - Vector3.new(0,3,0)
                farmPart.Parent = workspace

                fnafFarm = true
            else
                if fnafSaved then root.CFrame = fnafSaved end
                if farmPart then farmPart:Destroy() end
                fnafFarm = false
            end
        end

        local bFnafEsp = CreateHackButton("ANIM ESP", TabFnaf, function()
            if fnafEsp then espOff() else espOn() end
            bFnafEsp.Text = "  > ANIM ESP [" .. (fnafEsp and "ON" or "OFF") .. "]"
        end)

        local bFnafFuse = CreateHackButton("FUSE ESP", TabFnaf, function()
            if fnafFuse then fuseOff() else fuseOn() end
            bFnafFuse.Text = "  > FUSE ESP [" .. (fnafFuse and "ON" or "OFF") .. "]"
        end)

        local bFnafClock = CreateHackButton("CLOCK", TabFnaf, function()
            if fnafClock then clockOff() else clockOn() end
            bFnafClock.Text = "  > CLOCK [" .. (fnafClock and "ON" or "OFF") .. "]"
        end)

        local bFnafFarm = CreateHackButton("AUTO FARM", TabFnaf, function()
