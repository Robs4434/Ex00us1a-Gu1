local maxZoom, minZoom, XRAY_TRANSPARENCY, MAX_RAY_DISTANCE, hiddenParts, cameraActive, cameraButton = 1000, 0.5, 0.5, 1000, {}, false, nil
local function resetPreviousParts()
    for part, origTrans in pairs(hiddenParts) do if part and part.Parent then part.Transparency = origTrans end end
    table.clear(hiddenParts)
end
cameraButton = CreateHackButton("Camera Tweak ❌", TabVisuals, function()
    cameraActive = not cameraActive
    local camera = workspace.CurrentCamera
    if cameraActive then
        cameraButton.Text = "  > Camera Tweak ✅"
        LogToConsole("Camera Tweak: Activated", COLORS.Accent)
        camera.CameraType, LocalPlayer.CameraMaxZoomDistance, LocalPlayer.CameraMinZoomDistance = Enum.CameraType.Custom, maxZoom, minZoom
        RunService:BindToRenderStep("ForsakenCameraPositionFix", Enum.RenderPriority.Camera.Value + 1, function()
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not root or not camera then return end
            local zoom = (camera.CFrame.Position - root.Position).Magnitude
            if zoom <= 2 then return end 
            local look = camera.CFrame.LookVector
            local targetPos = root.Position - (look * zoom) + Vector3.new(0, 2, 0)
            camera.CFrame = CFrame.new(targetPos, targetPos + look)
        end)
        RunService:BindToRenderStep("ForsakenCameraXRayFix", Enum.RenderPriority.Camera.Value + 2, function()
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not root or not camera then resetPreviousParts() return end
            local zoom = (camera.CFrame.Position - root.Position).Magnitude
            if zoom <= 2 then resetPreviousParts() return end
            local params = RaycastParams.new()
            params.FilterType, params.FilterDescendantsInstances, params.IgnoreWater = Enum.RaycastFilterType.Exclude, {char}, true
            local origin = root.Position + Vector3.new(0, 2, 0)
            local dest = camera.CFrame.Position
            local dir = dest - origin
            if dir.Magnitude > MAX_RAY_DISTANCE then dir = dir.Unit * MAX_RAY_DISTANCE; dest = origin + dir end
            local currentObstacles, currOrigin, currDir = {}, origin, dir
            for i = 1, 10 do
                local hit = workspace:Raycast(currOrigin, currDir, params)
                if hit and hit.Instance then
                    local part = hit.Instance
                    if part:IsA("BasePart") and part.CanCollide and part.Name ~= "Terrain" then
                        if not (part.Size.X > 80 or part.Size.Y > 80 or part.Size.Z > 80) and part.Transparency < 0.9 then
                            currentObstacles[part] = true
                            if not hiddenParts[part] then hiddenParts[part] = part.Transparency end
                            part.Transparency = XRAY_TRANSPARENCY
                        end
                    end
                    currOrigin = hit.Position + (dir.Unit * 0.1); currDir = dest - currOrigin
                    if currDir.Magnitude < 0.5 then break end
                else break end
            end
            for part, origTrans in pairs(hiddenParts) do
                if not currentObstacles[part] then
                    if part and part.Parent then part.Transparency = origTrans end
                    hiddenParts[part] = nil
                end
            end
        end)
    else
        cameraButton.Text = "  > Camera Tweak ❌"
        LogToConsole("Camera Tweak: Deactivated", Color3.fromRGB(255, 100, 100))
        RunService:UnbindFromRenderStep("ForsakenCameraPositionFix"); RunService:UnbindFromRenderStep("ForsakenCameraXRayFix")
        resetPreviousParts(); LocalPlayer.CameraMaxZoomDistance, LocalPlayer.CameraMinZoomDistance = 400, 0.5
    end
end)
LocalPlayer.CharacterRemoving:Connect(resetPreviousParts)

