-- === СИСТЕМА PATPAT (ПОГЛАЖИВАНИЕ) ===
local isPatting = false
local patPatActive = false

local function getHoveredPlayer()
    local target = Mouse.Target
    if target and target.Parent then
        local char = target.Parent
        if char:FindFirstChild("Humanoid") then return Players:GetPlayerFromCharacter(char) end
        if char.Parent and char.Parent:FindFirstChild("Humanoid") then return Players:GetPlayerFromCharacter(char.Parent) end
    end
    return nil
end

local function getRightArm(character)
    local arm = character:FindFirstChild("RightHand") or character:FindFirstChild("Right Arm")
    if not arm then
        for _, v in pairs(character:GetDescendants()) do
            if v:IsA("BasePart") and (v.Name:find("Arm") or v.Name:find("Hand")) and v.Name:find("Right") then return v end
        end
    end
    return arm
end

