patBtn = CreateHackButton("PatPat (Key R) [OFF]", TabMisc, function()
    patPatActive = not patPatActive
    if patPatActive then
        patBtn.Text = "  > PatPat (Key R) [ON]"
    else
        patBtn.Text = "  > PatPat (Key R) [OFF]"
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed or isPatting or not patPatActive then return end
    
    if input.KeyCode == Enum.KeyCode.R then
        local targetPlayer = getHoveredPlayer()
        
        if targetPlayer and targetPlayer.Character and LocalPlayer.Character then
            local myChar = LocalPlayer.Character
            local targetChar = targetPlayer.Character
            local targetHead = targetChar:FindFirstChild("Head")
            local myArm = getRightArm(myChar)
            
            if targetHead and myArm then
                isPatting = true
                
                local joints = {}
                for _, joint in pairs(myChar:GetDescendants()) do
                    if joint:IsA("Motor6D") and (joint.Part0 == myArm or joint.Part1 == myArm) then
                        joint.Enabled = false
                        table.insert(joints, joint)
                    end
                end
                
                print("Гладим ладонью с идеальными углами: " .. targetPlayer.Name)
                
                local startTime = tick()
                local duration = 2.0 
                
                local connection
                connection = RunService.Heartbeat:Connect(function()
                    local elapsed = tick() - startTime
                    if elapsed >= duration then
                        if connection then connection:Disconnect() end
                        return
                    end
                    
                    if myArm:IsA("BasePart") then myArm.LocalTransparencyModifier = 0 end
                    for _, child in pairs(myArm:GetChildren()) do
                        if child:IsA("BasePart") then child.LocalTransparencyModifier = 0 end
                    end
                    
                    local wave = math.sin(tick() * 15) * 0.1
                    local basePosition = targetHead.CFrame * CFrame.new(0, 1.4 + wave, 0.35)
                    local rotation = CFrame.Angles(math.rad(40), math.rad(45), math.rad(20))
                    
                    myArm.CFrame = basePosition * rotation
                end)
                
                task.spawn(function()
                    task.wait(duration)
                    if connection and connection.Connected then connection:Disconnect() end
                    for _, joint in pairs(joints) do joint.Enabled = true end
                    isPatting = false
                end)
            end
        end
    end
end)

