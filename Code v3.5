local noclipConnection, noclipActive, noclipBtn = nil, false, nil
noclipBtn = CreateHackButton("NoClip Mode [OFF]", TabMovement, function()
    noclipActive = not noclipActive
    if noclipActive then
        noclipBtn.Text = "  > NoClip Mode [ON]"
        noclipConnection = RunService.Stepped:Connect(function()
            local character = LocalPlayer.Character
            if character then
                for _, child in pairs(character:GetDescendants()) do
                    if child:IsA("BasePart") and child.CanCollide then
                        child.CanCollide = false
                    end
                end
            end
        end)
    else
        noclipBtn.Text = "  > NoClip Mode [OFF]"
        if noclipConnection then 
            noclipConnection:Disconnect() 
            noclipConnection = nil 
        end
        
        local character = LocalPlayer.Character
        if character then
            local coreParts = {"HumanoidRootPart", "Torso", "UpperTorso", "LowerTorso", "Head"}
            for _, partName in ipairs(coreParts) do
                local part = character:FindFirstChild(partName)
                if part and part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
    end
end)

local flyActive, flyConnection, flySpeed, flyBtn = false, nil, 50, nil
flyBtn = CreateHackButton("Fly Mode [OFF]", TabMovement, function()
    flyActive = not flyActive
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local hrp, humanoid = character.HumanoidRootPart, character:FindFirstChildOfClass("Humanoid")
    if flyActive then
        flyBtn.Text = "  > Fly Mode [ON]"
        if humanoid then humanoid.PlatformStand = true end
        local bv = Instance.new("BodyVelocity")
        bv.Name, bv.MaxForce, bv.P, bv.Velocity, bv.Parent = "FlyBV", Vector3.new(math.huge, math.huge, math.huge), 100000, Vector3.new(0, 0, 0), hrp
        local bg = Instance.new("BodyGyro")
        bg.Name, bg.MaxTorque, bg.P, bg.CFrame, bg.Parent = "FlyBG", Vector3.new(math.huge, math.huge, math.huge), 100000, hrp.CFrame, hrp
        flyConnection = RunService.RenderStepped:Connect(function()
            local cam = workspace.CurrentCamera
            if not hrp or not hrp.Parent then return end
            local currentBV, currentBG = hrp:FindFirstChild("FlyBV"), hrp:FindFirstChild("FlyBG")
            if not currentBV or not currentBG then return end
            local direction = Vector3.new(0, 0, 0)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then direction = direction + cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then direction = direction - cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then direction = direction - cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then direction = direction + cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then direction = direction + Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then direction = direction - Vector3.new(0, 1, 0) end
            currentBG.CFrame = cam.CFrame
            if direction.Magnitude > 0 then currentBV.Velocity = direction.Unit * flySpeed else currentBV.Velocity = Vector3.new(0, 0, 0) end
        end)
    else
        flyBtn.Text = "  > Fly Mode [OFF]"
        if flyConnection then flyConnection:Disconnect() flyConnection = nil end
        if hrp:FindFirstChild("FlyBV") then hrp.FlyBV:Destroy() end
        if hrp:FindFirstChild("FlyBG") then hrp.FlyBG:Destroy() end
        if humanoid then humanoid.PlatformStand = false end
    end
end)

