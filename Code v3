local maxZoom = 1000
local minZoom = 0.5
local XRAY_TRANSPARENCY = 0.5
local MAX_RAY_DISTANCE = 1000
local hiddenParts = {}
local cameraActive = false
local cameraButton = nil
local function resetPreviousParts()
    for part, originalTransparency in pairs(hiddenParts) do
        if part and part.Parent then part.Transparency = originalTransparency end
    end
    table.clear(hiddenParts)
end
cameraButton = CreateHackButton("Camera Tweak ❌", TabVisuals, function()
    cameraActive = not cameraActive
    local camera = workspace.CurrentCamera
    if cameraActive then
        cameraButton.Text = "  > Camera Tweak ✅"
        camera.CameraType = Enum.CameraType.Custom
        LocalPlayer.CameraMaxZoomDistance = maxZoom
        LocalPlayer.CameraMinZoomDistance = minZoom
        
        RunService:BindToRenderStep("ForsakenCameraPositionFix", Enum.RenderPriority.Camera.Value + 1, function()
            local character = LocalPlayer.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            if not rootPart or not camera then return end
            local currentZoom = (camera.CFrame.Position - rootPart.Position).Magnitude
            if currentZoom <= 2 then return end 
            local lookVector = camera.CFrame.LookVector
            local targetPosition = rootPart.Position - (lookVector * currentZoom) + Vector3.new(0, 2, 0)
            camera.CFrame = CFrame.new(targetPosition, targetPosition + lookVector)
        end)

        RunService:BindToRenderStep("ForsakenCameraXRayFix", Enum.RenderPriority.Camera.Value + 2, function()
            local character = LocalPlayer.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            if not rootPart or not camera then resetPreviousParts() return end
            local currentZoom = (camera.CFrame.Position - rootPart.Position).Magnitude
            if currentZoom <= 2 then resetPreviousParts() return end

            local raycastParams = RaycastParams.new()
            raycastParams.FilterType = Enum.RaycastFilterType.Exclude
            raycastParams.FilterDescendantsInstances = {character}
            raycastParams.IgnoreWater = true

            local origin = rootPart.Position + Vector3.new(0, 2, 0)
            local destination = camera.CFrame.Position
            local direction = destination - origin

            if direction.Magnitude > MAX_RAY_DISTANCE then
                direction = direction.Unit * MAX_RAY_DISTANCE
                destination = origin + direction
            end

            local currentObstacles = {}
            local currentOrigin = origin
            local currentDirection = direction

            for i = 1, 10 do
                local raycastResult = workspace:Raycast(currentOrigin, currentDirection, raycastParams)
                if raycastResult and raycastResult.Instance then
                    local hitPart = raycastResult.Instance
                    if hitPart:IsA("BasePart") and hitPart.CanCollide and hitPart.Name ~= "Terrain" then
                        local size = hitPart.Size
                        local isSkyboxOrHugeWall = (size.X > 80 or size.Y > 80 or size.Z > 80)
                        local isAlreadyInvisible = hitPart.Transparency >= 0.9
                        if not isSkyboxOrHugeWall and not isAlreadyInvisible then
                            currentObstacles[hitPart] = true
                            if not hiddenParts[hitPart] then hiddenParts[hitPart] = hitPart.Transparency end
                            hitPart.Transparency = XRAY_TRANSPARENCY
                        end
                    end
                    currentOrigin = raycastResult.Position + (direction.Unit * 0.1)
                    currentDirection = destination - currentOrigin
                    if currentDirection.Magnitude < 0.5 then break end
                else
                    break
                end
            end
            for part, originalTransparency in pairs(hiddenParts) do
                if not currentObstacles[part] then
                    if part and part.Parent then part.Transparency = originalTransparency end
                    hiddenParts[part] = nil
                end
            end
        end)
    else
        cameraButton.Text = "  > Camera Tweak ❌"
        RunService:UnbindFromRenderStep("ForsakenCameraPositionFix")
        RunService:UnbindFromRenderStep("ForsakenCameraXRayFix")
        resetPreviousParts()
        LocalPlayer.CameraMaxZoomDistance = 400
        LocalPlayer.CameraMinZoomDistance = 0.5
    end
end)
